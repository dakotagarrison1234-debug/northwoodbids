generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrgStatus {
  APPROVED
  LIVE
  REJECTED
}

model Organization {
  id                     String      @id @default(cuid())
  name                   String
  slug                   String      @unique
  description            String?
  logoUrl                String?
  status                 OrgStatus   @default(APPROVED)
  stripeAccountId        String?     @unique
  stripeChargesEnabled   Boolean     @default(true)
  stripePayoutsEnabled   Boolean     @default(false)
  stripeDetailsSubmitted Boolean     @default(false)
  platformFeePercent     Decimal     @default(15) @db.Decimal(5, 2)
  taxPercent             Decimal     @default(6) @db.Decimal(5, 2)
  taxExempt              Boolean     @default(false)
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  auctions               Auction[]
  items                  Item[]
  members                OrgMember[]
  invites                OrgInvite[]
  bidderCustomers        BidderStripeCustomer[]
  bidderFollowers        BidderProfile[]
  pickupLocations        PickupLocation[]
  pickupAppointments     PickupAppointment[]
  transferRequests       TransferRequest[]
}

model OrgMember {
  id             String       @id @default(cuid())
  clerkUserId    String
  organizationId String
  role           OrgRole      @default(STAFF)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([clerkUserId, organizationId])
}

enum OrgRole {
  OWNER
  ADMIN
  STAFF
}model Auction {
  id                   String        @id @default(cuid())
  organizationId       String
  title                String
  description          String?
  startAt              DateTime
  endAt                DateTime
  status               AuctionStatus @default(DRAFT)
  slug                 String
  endingSoonNotifiedAt DateTime?
  // When the manual "auction is live" blast was sent. Set once — the button greys
  // out afterwards so nobody double-texts the whole bidder list.
  liveNotifiedAt       DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items                Item[]

  @@unique([organizationId, slug])
  @@index([status])
  @@index([organizationId, status])
  @@index([status, endAt])
}

enum AuctionStatus {
  DRAFT
  OPEN
  CLOSING
  CLOSED
  SETTLED
}model Item {
  id              String       @id @default(cuid())
  organizationId  String
  auctionId       String?
  uniqueId        String       @unique @default(cuid())
  title           String
  description     String?
  condition       Condition    @default(GOOD)
  category        String?
  retailValue     Decimal?     @db.Decimal(10, 2)
  startingBid     Decimal      @default(0) @db.Decimal(10, 2)
  reservePrice    Decimal?     @db.Decimal(10, 2)
  currentBid      Decimal      @default(0) @db.Decimal(10, 2)
  donorName       String?
  taxDeductible   Boolean      @default(false)
  itemCode        String?
  storageLocation String?
  notes           String?
  status          ItemStatus   @default(DRAFT)
  isPremium       Boolean      @default(false)
  // False = must be collected at its own warehouse; never auto-transferred.
  transferable    Boolean      @default(true)
  // Combo/pack lot: number of items sold together as ONE lot (null/1 = normal item).
  // Purely a display flag — the item's photos render as a collage with an "N-Pack" badge.
  packSize        Int?
  itemEndAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auction         Auction?     @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  photos          ItemPhoto[]
  bids            Bid[]
  payments        Payment[]
  proxyBids       ProxyBid[]
  pickedUpAt          DateTime?
  pickupAppointmentId String?
  pickupAppointment   PickupAppointment? @relation(fields: [pickupAppointmentId], references: [id], onDelete: SetNull)
  locationId          String?
  location            PickupLocation?    @relation("ItemLocation", fields: [locationId], references: [id], onDelete: SetNull)
  transferRequestId   String?
  transferRequest     TransferRequest?   @relation(fields: [transferRequestId], references: [id], onDelete: SetNull)

  @@index([status, itemEndAt])
  @@index([auctionId, status])
  @@index([pickupAppointmentId])
  @@index([locationId])
  @@index([organizationId, status])
  @@index([itemCode])
}

model PickupLocation {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  address        String?
  instructions   String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  windows        PickupWindow[]
  blackouts      PickupBlackout[]
  appointments   PickupAppointment[]
  items          Item[]             @relation("ItemLocation")
  transfersTo    TransferRequest[]  @relation("TransferTo")

  @@index([organizationId])
}

// Block-off dates (vacations, holidays) — no pickup slots are offered on any day
// within [startDate, endDate] (inclusive), regardless of the weekly hours.
model PickupBlackout {
  id         String         @id @default(cuid())
  locationId String
  startDate  DateTime       @db.Date
  endDate    DateTime       @db.Date
  reason     String?
  createdAt  DateTime       @default(now())
  location   PickupLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model PickupWindow {
  id              String         @id @default(cuid())
  locationId      String
  weekday         Int            // 0 = Sunday … 6 = Saturday
  startMinutes    Int            // minutes from midnight (e.g. 540 = 9:00am)
  endMinutes      Int            // minutes from midnight (e.g. 1020 = 5:00pm)
  slotMinutes     Int            @default(30)
  capacityPerSlot Int            @default(2)
  isActive        Boolean        @default(true)
  location        PickupLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model PickupAppointment {
  id             String            @id @default(cuid())
  organizationId String
  clerkUserId    String
  locationId     String
  startsAt       DateTime
  status         PickupApptStatus  @default(SCHEDULED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location       PickupLocation    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  items          Item[]

  @@index([organizationId, startsAt])
  @@index([clerkUserId, status])
}

enum PickupApptStatus {
  SCHEDULED
  COLLECTED
  CANCELLED
}

model TransferRequest {
  id             String         @id @default(cuid())
  organizationId String
  clerkUserId    String
  toLocationId   String
  status         TransferStatus @default(REQUESTED)
  notes          String?
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  toLocation     PickupLocation @relation("TransferTo", fields: [toLocationId], references: [id], onDelete: Cascade)
  items          Item[]

  @@index([organizationId, status])
  @@index([clerkUserId, status])
}

enum TransferStatus {
  REQUESTED
  LOADED
  COMPLETED
  CANCELLED
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ItemStatus {
  DRAFT
  ACTIVE
  SOLD
  UNSOLD
  PENDING_PICKUP
  PICKED_UP
}model ItemPhoto {
  id        String   @id @default(cuid())
  itemId    String
  url       String
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Bid {
  id          String    @id @default(cuid())
  itemId      String
  clerkUserId String
  amount      Decimal   @db.Decimal(10, 2)
  status      BidStatus @default(ACTIVE)
  isProxy     Boolean   @default(false)
  placedAt    DateTime  @default(now())
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([itemId, status, amount])
  @@index([clerkUserId])
  @@index([clerkUserId, placedAt])
}

model ProxyBid {
  id          String   @id @default(cuid())
  itemId      String
  clerkUserId String
  maxAmount   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, clerkUserId])
  @@index([itemId, isActive])
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  CANCELLED
}

model Payment {
  id                    String        @id @default(cuid())
  clerkUserId           String
  itemId                String
  amount                Decimal       @db.Decimal(10, 2)
  applicationFeeAmount  Decimal?      @db.Decimal(10, 2)
  taxAmount             Decimal?      @db.Decimal(10, 2)
  creditApplied         Decimal?      @db.Decimal(10, 2)
  stripePaymentIntentId String?
  status                PaymentStatus @default(PENDING)
  autoChargeAttemptedAt DateTime?
  failureReason         String?
  createdAt             DateTime      @default(now())
  item                  Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([itemId, clerkUserId])
  @@index([stripePaymentIntentId])
  @@index([clerkUserId])
  @@index([status])
}

model BidderStripeCustomer {
  id                     String       @id @default(cuid())
  clerkUserId            String
  organizationId         String
  stripeCustomerId       String
  defaultPaymentMethodId String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([clerkUserId, organizationId])
  @@index([clerkUserId])
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}
model BidderProfile {
  id             String        @id @default(cuid())
  clerkUserId    String        @unique
  phone          String?
  email          String?
  name           String?
  avatarKey      String?
  preferredOrgId String?
  preferredOrg   Organization? @relation(fields: [preferredOrgId], references: [id])
  // The bidder's chosen pickup location. Items won here are "ready"; items won
  // elsewhere are auto-transferred here. Cleared/changed via "switch location".
  preferredPickupLocationId String?
  blocked        Boolean       @default(false)
  blockedAt      DateTime?
  blockedReason  String?
  // Last time we sent a "we miss you" win-back text, so we never re-text too soon.
  lastWinbackAt  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
}

model GameScore {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  name        String?
  avatarKey   String?
  bestScore   Int      @default(0)
  plays       Int      @default(0)
  updatedAt   DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  @@index([bestScore])
}

model OrgApplication {
  id           String            @id @default(cuid())
  clerkUserId  String
  orgName      String
  slug         String
  description  String?
  website      String?
  contactName  String
  contactEmail String
  contactPhone String?
  status       ApplicationStatus @default(PENDING)
  reviewedBy   String?
  reviewNote   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([clerkUserId])
  @@index([status])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole      @default(STAFF)
  token          String       @unique @default(cuid())
  clerkUserId    String?
  accepted       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

// ── Bid Bucks referral program ────────────────────────────────────────────────
//
// Each bidder gets ONE permanent share code. When a brand-new bidder signs up
// through that code, a Referral(PENDING) row is created. The inviter's $5 only
// becomes real ("EARNED") once the referred bidder PAYS for their first won
// item — at which point anti-abuse checks run (no self-referral, no shared phone
// or card) and the per-inviter cap of 5 earned referrals is enforced. Credit is
// tracked as a ledger and redeemed one $5 per qualifying bill ($5 or more).

/** One permanent share code per bidder. */
model ReferralCode {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  code        String   @unique
  createdAt   DateTime @default(now())

  @@index([code])
}

enum ReferralStatus {
  PENDING // signed up via link; referred bidder hasn't paid yet
  EARNED  // referred bidder paid -> inviter granted $5 Bid Bucks
  CAPPED  // referred bidder paid, but inviter already had 5 earned -> no credit
  BLOCKED // failed an anti-abuse check (self / shared phone / shared card)
}

/** Attribution of a referred bidder to their inviter. One per referred bidder, ever. */
model Referral {
  id             String         @id @default(cuid())
  referrerUserId String         // inviter (clerkUserId)
  referredUserId String         @unique // the new bidder — locked to one inviter forever
  code           String         // the code used at signup
  status         ReferralStatus @default(PENDING)
  earnedAt       DateTime?      // when it became EARNED/CAPPED (referred bidder's first payment)
  blockedReason  String?        // why it was BLOCKED, if applicable
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([referrerUserId, status])
  @@index([code])
}

/**
 * Append-only Bid Bucks ledger. Positive = earned, negative = redeemed.
 * Balance for a user is SUM(amount). Uniqueness on referralId prevents a single
 * referral from ever granting credit twice; uniqueness on redemptionKey prevents
 * a single bill from ever redeeming credit twice (idempotent re-charges).
 */
model CreditLedger {
  id            String   @id @default(cuid())
  clerkUserId   String
  amount        Decimal  @db.Decimal(10, 2) // +5 earned, -N redeemed
  reason        String   // "referral_earned" | "referral_redeemed" | "adjustment"
  referralId    String?  @unique // set on earn rows — guarantees one grant per referral
  redemptionKey String?  @unique // set on redeem rows — guarantees one redeem per bill
  createdAt     DateTime @default(now())

  @@index([clerkUserId])
}

